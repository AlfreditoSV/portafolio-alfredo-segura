  <!-- ═══════════════════════ CONTACTO ═══════════════════════ -->
  <section class="section" id="contact" aria-label="Contacto">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">05. Contacto</span>
        <h2 class="section-title">¿Trabajamos <span class="gradient-text">juntos?</span></h2>
        <p class="section-subtitle">Estoy disponible para proyectos freelance y oportunidades laborales</p>
      </div>

      <div class="contact-layout">
        <div class="contact-info reveal">
          <h3 class="contact-info-title">Hablemos</h3>
          <p class="contact-info-text">
            Si tienes un proyecto en mente, buscas un desarrollador para tu equipo,
            o simplemente quieres hacer networking, ¡no dudes en escribirme!
          </p>

          <div class="contact-items">
            <a href="mailto:pixxo2010@gmail.com" class="contact-item" id="contact-email-link">
              <div class="contact-item-icon"><i class="fa-solid fa-envelope"></i></div>
              <div>
                <span class="contact-item-label">Email</span>
                <span class="contact-item-value">pixxo2010@gmail.com</span>
              </div>
            </a>
            <a href="https://github.com/AlfreditoSV" target="_blank" rel="noopener noreferrer" class="contact-item" id="contact-github-link">
              <div class="contact-item-icon"><i class="fa-brands fa-github"></i></div>
              <div>
                <span class="contact-item-label">GitHub</span>
                <span class="contact-item-value">github.com/alfredo-segura</span>
              </div>
            </a>
            <a href="https://www.linkedin.com/in/alfredoseguravara" target="_blank" rel="noopener noreferrer" class="contact-item" id="contact-linkedin-link">
              <div class="contact-item-icon"><i class="fa-brands fa-linkedin"></i></div>
              <div>
                <span class="contact-item-label">LinkedIn</span>
                <span class="contact-item-value">linkedin.com/in/alfredo-segura</span>
              </div>
            </a>
          </div>
        </div>

        <form
          class="contact-form reveal"
          id="contactForm"
          action="https://formsubmit.co/pixxo2010@gmail.com"
          method="POST"
        >
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_subject" value="Nuevo mensaje desde tu portafolio" />
          <input type="hidden" name="_template" value="table" />

          <div class="form-group">
            <label for="contact-name" class="form-label">Nombre completo</label>
            <div class="input-wrapper">
              <i class="fa-solid fa-user input-icon"></i>
              <input type="text" id="contact-name" name="name" class="form-input" placeholder="Tu nombre" required />
            </div>
          </div>

          <div class="form-group">
            <label for="contact-email" class="form-label">Correo electrónico</label>
            <div class="input-wrapper">
              <i class="fa-solid fa-envelope input-icon"></i>
              <input type="email" id="contact-email" name="email" class="form-input" placeholder="tu@correo.com" required />
            </div>
          </div>

          <div class="form-group">
            <label for="contact-subject" class="form-label">Asunto</label>
            <div class="input-wrapper">
              <i class="fa-solid fa-tag input-icon"></i>
              <input type="text" id="contact-subject" name="subject" class="form-input" placeholder="¿De qué quieres hablar?" />
            </div>
          </div>

          <div class="form-group">
            <label for="contact-message" class="form-label">Mensaje</label>
            <div class="input-wrapper textarea-wrapper">
              <i class="fa-solid fa-message input-icon textarea-icon"></i>
              <textarea id="contact-message" name="message" class="form-input form-textarea" placeholder="Cuéntame sobre tu proyecto o propuesta..." rows="5" required></textarea>
            </div>
          </div>

          <button type="submit" class="btn btn-primary btn-full" id="submit-contact-btn">
            <i class="fa-solid fa-paper-plane"></i>
            Enviar mensaje
            <span class="btn-shimmer"></span>
          </button>
        </form>
      </div>
    </div>
  </section>

