  <!-- Modal de Compartir Portafolio -->
  <div id="share-modal" class="share-modal">
    <div class="share-modal-wrapper">
      <div class="share-modal-content glass-panel">
        <button class="share-modal-close" id="share-modal-close" aria-label="Cerrar modal"><i class="fa-solid fa-xmark"></i></button>
        <h3 class="modal-title">Compartir Portafolio</h3>
        <p class="modal-desc">Escanea el código QR o comparte directamente en redes.</p>
        
        <div class="modal-qr-container">
          <div class="qr-frame">
            <img id="nav-modal-qr-img" src="data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxNTAiIGhlaWdodD0iMTUwIj48L3N2Zz4=" alt="Código QR del Portafolio" width="160" height="160" crossorigin="anonymous" loading="lazy">
          </div>
          <span class="qr-scan-label">Enlace Directo Generado</span>
        </div>
        
        <div class="modal-social-links">
          <a href="#" id="nav-modal-wa" target="_blank" rel="noopener noreferrer" class="social-share-btn wa">
            <i class="fa-brands fa-whatsapp"></i> WhatsApp
          </a>
          <a href="#" id="nav-modal-li" target="_blank" rel="noopener noreferrer" class="social-share-btn li">
            <i class="fa-brands fa-linkedin-in"></i> LinkedIn
          </a>
        </div>
