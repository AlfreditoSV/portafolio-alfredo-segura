  <!-- ═══════════════════════ HERO ═══════════════════════ -->
  <section class="hero" id="hero" aria-label="Presentación">
    <div class="hero-orbs">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>

    <div class="hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Disponible para nuevos proyectos
      </div>

      <h1 class="hero-title">
        Hola, soy<br />
        <span class="gradient-text">Alfredo Segura</span>
      </h1>

      <div class="hero-subtitle">
        <span class="typewriter" id="typewriter"></span>
        <span class="cursor-blink">|</span>
      </div>

      <p class="hero-description">
        Desarrollador de Software con experiencia en desarrollo web full stack,<br class="desktop-br" />
        creación de soluciones escalables y soporte de sistemas en producción.
      </p>

      <div class="hero-ctas">
        <a href="#projects" class="btn btn-primary" id="hero-projects-btn">
          <i class="fa-solid fa-rocket"></i> Ver Proyectos
        </a>
        <a href="#contact" class="btn btn-glass" id="hero-contact-btn">
          <i class="fa-solid fa-paper-plane"></i> Contáctame
        </a>
      </div>

      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number" data-target="5">0</span><span class="stat-plus">+</span>
          <span class="stat-label">Años de experiencia</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number" data-target="20">0</span><span class="stat-plus">+</span>
          <span class="stat-label">Proyectos entregados</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number" data-target="12">0</span><span class="stat-plus">+</span>
          <span class="stat-label">Tecnologías</span>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="avatar-wrapper">
        <div class="avatar-ring ring-1"></div>
        <div class="avatar-ring ring-2"></div>
        <div class="avatar-ring ring-3"></div>
        <img src="/portafolio-alfredo-segura/images/avatar.png" alt="Alfredo Segura Vara" class="avatar-img" />
        <div class="avatar-badge-code">
          <i class="fa-solid fa-code"></i>
        </div>
      </div>
    </div>

    <div class="hero-scroll-indicator" id="scrollIndicator">
      <span>Scroll</span>
      <div class="scroll-arrow"></div>
    </div>
  </section>

