---
---
<!-- ═══════════════════════ CERTIFICACIONES ═══════════════════════ -->
<section class="section" id="certifications" aria-label="Certificaciones">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-tag">06. Certificaciones</span>
      <h2 class="section-title">Cursos y <span class="gradient-text">Logros</span></h2>
      <p class="section-subtitle">Formación continua y especializaciones tecnológicas</p>
    </div>

    <div class="cert-groups">
      <!-- Grupo Flutter -->
      <div class="cert-group-card reveal">
        <div class="cert-group-header">
          <div class="cert-group-icon" style="color: #0284c7; background: rgba(2,132,199,0.1); border-color: rgba(2,132,199,0.2);">
             <i class="fa-solid fa-mobile-screen"></i>
          </div>
          <div>
            <h3 class="cert-group-title">Especialización en Móvil (Flutter & Dart)</h3>
            <p class="cert-platform"><i class="fa-solid fa-chalkboard-user"></i> Udemy</p>
          </div>
        </div>
        <div class="cert-capsules">
          <div class="cert-capsule">
            <span class="cert-name">Flutter - Móvil: De cero a experto</span>
            <span class="cert-year">2025</span>
          </div>
          <div class="cert-capsule">
            <span class="cert-name">Flutter Móvil: Recursos Nativos (Medio)</span>
            <span class="cert-year">2025</span>
          </div>
          <div class="cert-capsule">
            <span class="cert-name">Dart: De cero hasta los detalles</span>
            <span class="cert-year">2024</span>
          </div>
        </div>
      </div>

      <!-- Grupo PHP Laravel -->
      <div class="cert-group-card reveal">
        <div class="cert-group-header">
          <div class="cert-group-icon" style="color: #db2777; background: rgba(219,39,119,0.1); border-color: rgba(219,39,119,0.2);">
             <i class="fa-solid fa-server"></i>
          </div>
          <div>
            <h3 class="cert-group-title">Ruta Desarrollo Backend (PHP & Laravel)</h3>
            <p class="cert-platform"><i class="fa-solid fa-chalkboard-user"></i> Platzi</p>
          </div>
        </div>
        <div class="cert-capsules">
          <div class="cert-capsule"><span class="cert-name">API REST con Laravel</span><span class="cert-year">2023</span></div>
          <div class="cert-capsule"><span class="cert-name">Patrones de Diseño y Buenas Prácticas PHP</span><span class="cert-year">2023</span></div>
          <div class="cert-capsule"><span class="cert-name">PHP: Entornos Virtuales y Funciones Avanzadas</span><span class="cert-year">2023</span></div>
          <div class="cert-capsule"><span class="cert-name">Curso Práctico e Instalación y PHP Básico</span><span class="cert-year">2022</span></div>
          <div class="cert-capsule"><span class="cert-name">Introducción al Desarrollo Backend</span><span class="cert-year">2022</span></div>
        </div>
      </div>

      <!-- Diseño y Front -->
      <div class="cert-group-card reveal">
        <div class="cert-group-header">
          <div class="cert-group-icon" style="color: #f59e0b; background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.2);">
             <i class="fa-solid fa-paintbrush"></i>
          </div>
          <div>
            <h3 class="cert-group-title">Frontend, UI y Diseño Digital</h3>
            <p class="cert-platform"><i class="fa-solid fa-globe"></i> Libre y Múltiples Plataformas</p>
          </div>
        </div>
        <div class="cert-capsules">
          <div class="cert-capsule"><span class="cert-name">Responsive Web Design (freeCodeCamp)</span><span class="cert-year">2022</span></div>
          <div class="cert-capsule"><span class="cert-name">Diseño Web Profesional desde Cero (Udemy)</span><span class="cert-year">2022</span></div>
          <div class="cert-capsule"><span class="cert-name">Creación de Blogs con WordPress (Platzi)</span><span class="cert-year">2022</span></div>
          <div class="cert-capsule"><span class="cert-name">Conceptos Básicos de Animación 3D en Maya 2018</span><span class="cert-year">2022</span></div>
          <div class="cert-capsule"><span class="cert-name">Photoshop para novatos (Udemy)</span><span class="cert-year">2017</span></div>
          <div class="cert-capsule"><span class="cert-name">Programación Front-End (FalconMasters)</span></div>
        </div>
      </div>

      <!-- Fundamentos Logica -->
      <div class="cert-group-card reveal">
        <div class="cert-group-header">
          <div class="cert-group-icon" style="color: #10b981; background: rgba(16,185,129,0.1); border-color: rgba(16,185,129,0.2);">
             <i class="fa-solid fa-network-wired"></i>
          </div>
          <div>
            <h3 class="cert-group-title">Fundamentos Informáticos e Idiomas</h3>
            <p class="cert-platform"><i class="fa-solid fa-book"></i> Platzi / UVEG / Duolingo</p>
          </div>
        </div>
        <div class="cert-capsules">
          <div class="cert-capsule"><span class="cert-name">Pensamiento Lógico: Algoritmos y Manejo de Datos</span><span class="cert-year">2022</span></div>
          <div class="cert-capsule"><span class="cert-name">Pensamiento Lógico y Lenguajes (Introd. C#)</span><span class="cert-year">2022</span></div>
          <div class="cert-capsule"><span class="cert-name">Computación Básica</span><span class="cert-year">2022</span></div>
          <div class="cert-capsule"><span class="cert-name">Nivel Básico Centro de Idiomas (UVEG)</span><span class="cert-year">2022</span></div>
          <div class="cert-capsule"><span class="cert-name">Fluidez Inglés Básico (Duolingo)</span><span class="cert-year">2016</span></div>
        </div>
      </div>

    </div>
  </div>
</section>
