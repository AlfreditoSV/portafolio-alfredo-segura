      </div>

      <div class="contact-info">
        <div><i class="fa-solid fa-location-dot"></i> Estado de México, México</div>
        <div>
          <a href="mailto:pixxo2010@gmail.com" class="contact-link" target="_blank" rel="noopener noreferrer">
            <i class="fa-solid fa-envelope"></i> pixxo2010@gmail.com
          </a>
        </div>
        <div>
          <a href="https://wa.me/525564207271" class="contact-link" target="_blank" rel="noopener noreferrer">
            <i class="fa-brands fa-whatsapp"></i> +52 55 64 20 72 71
          </a>
