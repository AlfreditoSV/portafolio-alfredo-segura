---
// Plantilla de Curriculum Vitae Optimizada para Impresión / PDF
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Curriculum Vitae - Alfredo Segura Vara</title>
  <meta name="description" content="Curriculum Vitae de Alfredo Segura Vara. Desarrollador especializado en Laravel, Flutter, PHP y JavaScript.">
  <meta name="keywords" content="Alfredo Segura, Alfredo Segura Vara, desarrollador software, Laravel, PHP, JavaScript, Livewire, Flutter, Dart, GCP, Tailwind CSS, API REST, full stack developer, México, portafolio, cv, curriculum vitae">
  <meta name="author" content="Alfredo Segura Vara">
  <meta name="robots" content="index, follow">
  
  <!-- Open Graph / Redes Sociales -->
  <meta property="og:title" content="CV - Alfredo Segura Vara | Desarrollador de Software">
  <meta property="og:description" content="Trayectoria, experiencia y habilidades como desarrollador web y móvil.">
  <meta property="og:type" content="profile">
  <meta property="og:url" content="https://alfreditosv.github.io/portafolio-alfredo-segura/cv">
  <meta property="og:image" content="https://alfreditosv.github.io/portafolio-alfredo-segura/images/cv-preview.png">
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="CV - Alfredo Segura Vara | Desarrollador de Software">
  <meta name="twitter:description" content="Trayectoria, experiencia y habilidades como desarrollador web y móvil.">
  <meta name="twitter:image" content="https://alfreditosv.github.io/portafolio-alfredo-segura/images/cv-preview.png">

  <!-- Seguridad Extra (Cabeceras recomendadas simuladas para el doc) -->
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-CPMG1Z4850"></script>
  <!-- Script Dinámico para Enlaces de Compartir y QR -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Set canonical/dynamic url if hosted
      const currentUrl = encodeURIComponent(window.location.href);
      const title = encodeURIComponent("CV - Alfredo Segura Vara | Programador Web y Móvil");
      
      const btnWa = document.getElementById('share-wa');
      const btnLi = document.getElementById('share-li');
      
      if(btnWa) btnWa.href = `https://api.whatsapp.com/send?text=${title}%20${currentUrl}`;
      if(btnLi) btnLi.href = `https://www.linkedin.com/sharing/share-offsite/?url=${currentUrl}`;

      // Dynamic QR Code generation for offline scanning
      const qrCodeImg = document.getElementById('qr-code-img');
      if(qrCodeImg) {
        // We use QR Server API.
        qrCodeImg.src = `https://api.qrserver.com/v1/create-qr-code/?size=120x120&data=${currentUrl}&margin=0&color=1a1a1a`;
      }
    });

    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-CPMG1Z4850');
  </script>
  
  <style>
    /* Estilos in línea para garantizar que funcionen en modo PDF de forma infalible */
    :root {
      --clr-text: #1a1a1a;
      --clr-text-muted: #4b5563;
      --clr-primary: #7C3AED;
      --clr-secondary: #06B6D4;
      --font-heading: 'Outfit', sans-serif;
      --font-body: 'Inter', sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    body {
      font-family: var(--font-body);
      color: var(--clr-text);
      line-height: 1.5;
      background: #e5e7eb;
      font-size: 13px;
    }

    .a4-page {
      background: white;
      width: 210mm;
      min-height: 297mm;
      margin: 20px auto;
      padding: 15mm 20mm;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      position: relative;
    }

    @media print {
      body { background: white; margin: 0; }
      .a4-page { width: 100%; height: auto !important; min-height: 0 !important; margin: 0; padding: 10mm; box-shadow: none; break-after: auto; }
      .no-print { display: none !important; }
    }

    /* Top Bar Action */
    .action-bar {
      width: 210mm;
      margin: 20px auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #111827;
      color: white;
      padding: 15px 30px;
      border-radius: 12px;
    }

    .action-btn {
      background: linear-gradient(135deg, #7C3AED 0%, #06B6D4 100%);
      color: white;
      border: none;
      padding: 10px 20px;
      border-radius: 8px;
      font-family: var(--font-heading);
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: opacity 0.3s ease;
    }
    .action-btn:hover { opacity: 0.9; }

    .social-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      color: white;
      text-decoration: none;
      font-size: 16px;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }
    .social-btn:hover { transform: scale(1.05); }
    .social-btn.wa { background: #25D366; }
    .social-btn.li { background: #0077b5; }
    .share-actions span { color: #9ca3af; }

    /* Layout */
    .header {
      border-bottom: 2px solid var(--clr-primary);
      padding-bottom: 12px;
      margin-bottom: 20px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .name-title h1 {
      font-family: var(--font-heading);
      font-size: 32px;
      color: var(--clr-primary);
      line-height: 1.1;
    }
    .name-title h2 {
      font-family: var(--font-heading);
      font-size: 18px;
      color: var(--clr-text-muted);
      font-weight: 500;
      margin-top: 5px;
    }

    .contact-info {
      text-align: right;
      font-size: 11.5px;
      color: var(--clr-text-muted);
    }
    .contact-info div { margin-bottom: 4px; }
    .contact-info i { color: var(--clr-secondary); width: 16px; text-align: center; margin-right: 5px; }
    
    .contact-link {
      color: inherit;
      text-decoration: none;
      transition: color 0.2s;
    }
    .contact-link:hover {
      color: var(--clr-primary);
    }
    
    .header-middle {
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: flex-end;
      padding-bottom: 5px;
    }
    .qr-container {
      text-align: center;
      background: white;
      padding: 5px;
      border-radius: 8px;
      border: 1px solid #e5e7eb;
    }
    .qr-container img {
      display: block;
      margin: 0 auto;
    }
    .qr-label {
      font-size: 7.5px;
      font-weight: 700;
      color: var(--clr-primary);
      margin-top: 3px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .grid-container {
      display: block;
    }
    .grid-container::after {
      content: "";
      display: table;
      clear: both;
    }
    .main-column {
      float: left;
      width: 65%;
      padding-right: 30px;
    }
    .side-column {
      float: left;
      width: 35%;
    }

    .section-title {
      font-family: var(--font-heading);
      font-size: 16px;
      color: var(--clr-primary);
      text-transform: uppercase;
      border-bottom: 1px solid #e5e7eb;
      padding-bottom: 5px;
      margin-bottom: 12px;
      font-weight: 700;
      letter-spacing: 1px;
    }

    .profile-text {
      text-align: justify;
      margin-bottom: 25px;
    }

    /* Experience */
    .job { margin-bottom: 15px; page-break-inside: avoid; break-inside: avoid; }
    .job-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 5px; }
    .job-title { font-weight: 700; font-family: var(--font-heading); font-size: 14px; }
    .job-date { font-size: 11px; color: var(--clr-secondary); font-weight: 600; }
    .job-company { font-weight: 600; color: var(--clr-text-muted); font-size: 12px; margin-bottom: 5px; }
    .job-desc { font-size: 12px; color: #374151; }

    /* Tags & Pills */
    .skills-group { margin-bottom: 15px; page-break-inside: avoid; break-inside: avoid; }
    .skills-title { font-size: 12px; font-weight: 700; margin-bottom: 5px; color: var(--clr-text-muted); }
    .skills-list { display: flex; flex-wrap: wrap; gap: 5px; }
    .skill-tag {
      background: #f3f4f6;
      color: #374151;
      padding: 3px 8px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 500;
    }

    /* Education & Certs */
    .ed-item { margin-bottom: 10px; page-break-inside: avoid; break-inside: avoid; }
    .ed-title { font-weight: 600; font-size: 13px; }
    .ed-school { font-size: 11px; color: var(--clr-text-muted); }
  </style>
</head>
<body>

  <div class="action-bar no-print">
    <div>
      <h3 style="font-family: 'Outfit';">Vista previa del PDF</h3>
      <p style="font-size: 12px; opacity: 0.8;">Para guardar, haz clic en el botón y selecciona "Guardar como PDF" en el destino.</p>
    </div>
    
    <div class="share-actions" style="display: flex; gap: 10px; align-items: center;">
      <span style="font-size: 12px; font-weight: 500;">Compartir:</span>
      <a href="#" id="share-wa" target="_blank" rel="noopener noreferrer" aria-label="Compartir en WhatsApp" class="social-btn wa">
        <i class="fa-brands fa-whatsapp"></i>
      </a>
      <a href="#" id="share-li" target="_blank" rel="noopener noreferrer" aria-label="Compartir en LinkedIn" class="social-btn li">
        <i class="fa-brands fa-linkedin-in"></i>
      </a>
      
      <button class="action-btn" onclick="window.print()" style="margin-left: 15px;">
        <i class="fa-solid fa-file-pdf"></i> Descargar / Imprimir
      </button>
    </div>
  </div>

  <div class="a4-page">
